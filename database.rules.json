{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",

        "dm_uid": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid) && root.child('users/' + auth.uid + '/subscription/tier').val() !== 'player'"
        },

        "players": {
          "$cName": {
            ".write": "auth != null && (root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || newData.child('authUid').val() === auth.uid || data.child('authUid').val() === auth.uid)",
            "userRole": {
              ".validate": "root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || newData.val() === 'player' || newData.val() === 'npc'"
            }
          }
        },

        "initiative": {
          "$cName": {
            ".write": "auth != null && (root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || root.child('rooms/' + $roomId + '/players/' + $cName + '/authUid').val() === auth.uid)"
          }
        },

        "combat_active": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "active_turn": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "round_number": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "display": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "map": {
          "tokens": {
            "$cName": {
              ".write": "auth != null && (root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || root.child('rooms/' + $roomId + '/players/' + $cName + '/authUid').val() === auth.uid)"
            }
          },
          "config": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          },
          "activeScene": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          },
          "atmosphere": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          }
        },

        "scenes": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "music": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "dm_notes": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "rolls": {
          ".write": "auth != null",
          ".indexOn": ["ts"]
        },

        "online": {
          ".write": "auth != null"
        },

        "webrtc": {
          "enabled": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          },
          "muteAll": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          },
          "participants": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid"
            }
          },
          "signals": {
            "$key": {
              ".write": "auth != null",
              ".read": "auth != null"
            }
          },
          "ice": {
            "$key": {
              ".write": "auth != null",
              ".read": "auth != null"
            }
          }
        },

        "pendingSaves": {
          "$cName": {
            ".write": "auth != null",
            ".read": "auth != null"
          }
        },
        "pendingReactions": {
          "$cName": {
            ".write": "auth != null",
            ".read": "auth != null"
          }
        }
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "campaigns": {
      "$cId": {
        ".write": "auth != null && !newData.exists() && (root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid || root.child('users/' + auth.uid + '/dmCampaigns/' + $cId).exists())",
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (newData.child('dmUid').val() === auth.uid || root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid) && root.child('users/' + auth.uid + '/subscription/tier').val() !== 'player'"
        },
        "allowedPlayers": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid"
          }
        },
        "bannedPlayers": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid"
          }
        },
        "pendingRequests": {
          ".read": "auth != null && root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid",
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid)",
            ".write": "auth != null && (auth.uid === $uid || root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid)"
          }
        },
        "mechanics": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid"
        }
      }
    },

    "admin": {
      ".read": "auth != null && auth.token.email === 'danielrigbi@gmail.com'",
      ".write": "auth != null && auth.token.email === 'danielrigbi@gmail.com'",
      "bugReports": {
        "$reportId": {
          ".write": "auth != null"
        }
      },
      "founderCount": {
        ".read": "auth != null"
      },
      "webhookLog": {
        ".read": "auth != null && auth.token.email === 'danielrigbi@gmail.com'"
      }
    },

    "communityHub": {
      "listings": {
        ".read": "auth != null",
        ".indexOn": ["createdAt", "status", "schedule/date"],
        "$listingId": {
          ".write": "auth != null && (newData.child('dmUid').val() === auth.uid || data.child('dmUid').val() === auth.uid) && root.child('users/' + auth.uid + '/subscription/tier').val() !== 'player'",
          "rsvps": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid"
            }
          }
        }
      },
      "userProfiles": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    }
  }
}
