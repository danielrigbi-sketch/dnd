{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",

        "dm_uid": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
        },

        "players": {
          "$cName": {
            ".write": "auth != null && (root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || newData.child('authUid').val() === auth.uid || data.child('authUid').val() === auth.uid)",
            "userRole": {
              ".validate": "root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || newData.val() === 'player' || newData.val() === 'npc'"
            }
          }
        },

        "initiative": {
          "$cName": {
            ".write": "auth != null && (root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || root.child('rooms/' + $roomId + '/players/' + $cName + '/authUid').val() === auth.uid)"
          }
        },

        "combat_active": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "active_turn": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "round_number": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "map": {
          "tokens": {
            "$cName": {
              ".write": "auth != null && (root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid || root.child('rooms/' + $roomId + '/players/' + $cName + '/authUid').val() === auth.uid)"
            }
          },
          "config": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          },
          "activeScene": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          },
          "atmosphere": {
            ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
          }
        },

        "scenes": {
          ".write": "auth != null && root.child('rooms/' + $roomId + '/dm_uid').val() === auth.uid"
        },

        "rolls": {
          ".write": "auth != null",
          ".indexOn": ["ts"]
        },

        "online": {
          ".write": "auth != null"
        }
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "campaigns": {
      "$cId": {
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (newData.child('dmUid').val() === auth.uid || root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid)"
        },
        "allowedPlayers": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid"
          }
        },
        "pendingRequests": {
          ".read": "auth != null && root.child('campaigns/' + $cId + '/meta/dmUid').val() === auth.uid",
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
